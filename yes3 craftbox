        // --- Mobile Menu Toggle ---
        const menuToggle = document.querySelector('.menu-toggle');
        const navList = document.querySelector('.nav-links');

        menuToggle.addEventListener('click', () => {
            const isExpanded = menuToggle.getAttribute('aria-expanded') === 'true';
            menuToggle.setAttribute('aria-expanded', !isExpanded);
            navList.classList.toggle('active');
        });

        // Close menu when link is clicked
        document.querySelectorAll('.nav-links a').forEach(link => {
            link.addEventListener('click', () => {
                navList.classList.remove('active');
                menuToggle.setAttribute('aria-expanded', 'false');
            });
        });

        // --- FAQ Accordion ---
        const faqTriggers = document.querySelectorAll('.faq-trigger');

        faqTriggers.forEach(trigger => {
            trigger.addEventListener('click', () => {
                const content = trigger.nextElementSibling;
                const isExpanded = trigger.getAttribute('aria-expanded') === 'true';

                // Close other open items
                faqTriggers.forEach(other => {
                    if (other !== trigger) {
                        other.setAttribute('aria-expanded', 'false');
                        other.nextElementSibling.style.maxHeight = null;
                        other.querySelector('span').textContent = '+';
                    }
                });

                // Toggle current item
                trigger.setAttribute('aria-expanded', !isExpanded);
                if (!isExpanded) {
                    content.style.maxHeight = content.scrollHeight + "px";
                    trigger.querySelector('span').textContent = '-';
                } else {
                    content.style.maxHeight = null;
                    trigger.querySelector('span').textContent = '+';
                }
            });
        });

        // --- Contact Form Validation ---
        const contactForm = document.getElementById('contactForm');
        const formSuccess = document.getElementById('formSuccess');

        contactForm.addEventListener('submit', (e) => {
            e.preventDefault();
            let isValid = true;

            const fields = [
                { id: 'name', errorId: 'nameError', validate: (v) => v.length > 0 },
                { id: 'email', errorId: 'emailError', validate: (v) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v) },
                { id: 'message', errorId: 'messageError', validate: (v) => v.length > 0 }
            ];

            fields.forEach(field => {
                const input = document.getElementById(field.id);
                const error = document.getElementById(field.errorId);
                if (!field.validate(input.value)) {
                    error.style.display = 'block';
                    isValid = false;
                } else {
                    error.style.display = 'none';
                }
            });

            if (isValid) {
                // Simulate form submission
                contactForm.querySelector('button').disabled = true;
                contactForm.querySelector('button').textContent = 'Sending...';
                
                setTimeout(() => {
                    contactForm.reset();
                    contactForm.querySelector('button').style.display = 'none';
                    formSuccess.style.display = 'block';
                }, 1500);
            }
        });

        // --- Global Utils ---
        document.getElementById('currentYear').textContent = new Date().getFullYear();

        // Basic Analytics Hook (Placeholder)
        // console.log("Analytics initialized.");
    </script>
</body>
</html>
